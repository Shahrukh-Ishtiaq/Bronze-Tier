# AI Employee Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to version control!

# ===========================================
# Vault Configuration
# ===========================================
VAULT_PATH=./AI_Employee_Vault

# ===========================================
# Watcher Configuration
# ===========================================
WATCHER_CHECK_INTERVAL=30
ORCHESTRATOR_CHECK_INTERVAL=60

# ===========================================
# Logging Configuration
# ===========================================
LOG_LEVEL=INFO
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL

# ===========================================
# Dry Run Mode (for testing)
# ===========================================
# Set to 'true' to prevent actual actions
DRY_RUN=true

# ===========================================
# Email Configuration (Future - Silver Tier)
# ===========================================
# GMAIL_CLIENT_ID=your_client_id
# GMAIL_CLIENT_SECRET=your_client_secret
# GMAIL_REDIRECT_URI=http://localhost:8080
# GMAIL_SCOPES=https://www.googleapis.com/auth/gmail.modify

# ===========================================
# WhatsApp Configuration (Future - Silver Tier)
# ===========================================
# WHATSAPP_SESSION_PATH=/secure/path/session

# ===========================================
# Banking/API Configuration (Future - Gold Tier)
# ===========================================
# BANK_API_TOKEN=your_token
# BANK_API_URL=https://api.bank.com

# ===========================================
# Qwen Code Configuration
# ===========================================
# QWEN_API_KEY=your_api_key
# QWEN_MODEL=claude-sonnet-4-5-20250929

# ===========================================
# Security Settings
# ===========================================
# Payment approval threshold (auto-approve below this)
PAYMENT_AUTO_APPROVE_THRESHOLD=50

# Maximum emails per hour
MAX_EMAILS_PER_HOUR=10

# Maximum payments per day
MAX_PAYMENTS_PER_DAY=5
